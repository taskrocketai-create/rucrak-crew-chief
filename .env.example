# Copy this file to .env.local for local testing with `vercel dev`.
# In production, set these in Vercel -> Project Settings -> Environment Variables instead.
# NEVER commit a real .env.local file with actual secrets to git.

# Required — your real key from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Recommended before going live — restricts who can call /api/chat.
# Example: https://rucrak.com
# Leave unset (or "*") during local testing.
ALLOWED_ORIGIN=*
